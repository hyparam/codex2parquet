{
  "name": "codex2parquet",
  "version": "1.0.0",
  "description": "CLI tool to export Codex session logs in parquet format",
  "author": "Hyperparam",
  "homepage": "https://hyperparam.app",
  "keywords": [
    "ai",
    "codex",
    "data",
    "hyperparam",
    "hyparquet",
    "ml",
    "parquet"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyparam/codex2parquet.git"
  },
  "files": [
    "src",
    "bin"
  ],
  "bin": {
    "codex2parquet": "bin/cli.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "type": "module",
  "main": "src/index.js",
  "sideEffects": false,
  "scripts": {
