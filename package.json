  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "9.39.2",
    "eslint-plugin-jsdoc": "62.9.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
