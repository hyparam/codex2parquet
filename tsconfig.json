{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": "types",
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "src/**/*.js",
    "bin/**/*.js"
  ]
}
